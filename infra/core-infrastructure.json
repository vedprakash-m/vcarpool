{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.35.1.17967",
      "templateHash": "13231793585474818943"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "appName": {
      "type": "string",
      "defaultValue": "vcarpool",
      "allowedValues": [
        "vcarpool"
      ],
      "metadata": {
        "description": "App name prefix for all resources"
      }
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "test",
        "prod"
      ],
      "metadata": {
        "description": "Environment name (dev, test, prod)"
      }
    },
    "vnetId": {
      "type": "string",
      "defaultValue": "",
      "allowedValues": [
        ""
      ],
      "metadata": {
        "description": "VNet ID for private endpoint configuration"
      }
    },
    "subnetName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Subnet name for private endpoint configuration"
      }
    }
  },
  "variables": {
    "environmentConfig": {
      "sku": "[if(equals(parameters('environmentName'), 'prod'), 'P1v2', 'B1')]",
      "tier": "[if(equals(parameters('environmentName'), 'prod'), 'PremiumV2', 'Basic')]",
      "cosmosThroughput": "[if(equals(parameters('environmentName'), 'prod'), 1000, 400)]",
      "enableAutoScale": "[equals(parameters('environmentName'), 'prod')]",
      "retentionDays": "[if(equals(parameters('environmentName'), 'prod'), 90, 30)]",
      "storageSku": "Standard_LRS",
      "functionAppRuntime": "node:18",
      "functionAppVersion": "~4"
    },
    "baseTags": {
      "application": "[parameters('appName')]",
      "environment": "[parameters('environmentName')]",
      "deployment": "bicep",
      "managedBy": "bicep",
      "costCenter": "vcarpool"
    },
    "storageAccountName": "[toLower(take(format('{0}{1}{2}', replace(parameters('appName'), '-', ''), parameters('environmentName'), uniqueString(resourceGroup().id)), 24))]",
    "storageSuffix": "[environment().suffixes.storage]",
    "privateDnsZoneName": "[format('privatelink.{0}', replace(replace(variables('storageSuffix'), 'https://', ''), 'http://', ''))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2021-08-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "tags": "[union(variables('baseTags'), createObject('storageType', variables('environmentConfig').storageSku, 'autoShutdown', if(not(equals(parameters('environmentName'), 'prod')), 'enabled', 'disabled')))]",
      "sku": {
        "name": "[variables('environmentConfig').storageSku]"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "accessTier": "Hot",
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "networkAcls": {
          "defaultAction": "Deny",
          "bypass": "AzureServices",
          "ipRules": [],
          "virtualNetworkRules": []
        },
        "publicNetworkAccess": "[if(not(empty(parameters('vnetId'))), 'Disabled', 'Enabled')]"
      }
    },
    {
      "condition": "[and(not(empty(parameters('vnetId'))), equals(parameters('environmentName'), 'prod'))]",
      "type": "Microsoft.Network/privateEndpoints",
      "apiVersion": "2021-05-01",
      "name": "[format('{0}-pe', variables('storageAccountName'))]",
      "location": "[parameters('location')]",
      "properties": {
        "subnet": {
          "id": "[format('{0}/subnets/{1}', parameters('vnetId'), parameters('subnetName'))]"
        },
        "privateLinkServiceConnections": [
          {
            "name": "[format('{0}-pls-conn', variables('storageAccountName'))]",
            "properties": {
              "privateLinkServiceId": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
              "groupIds": [
                "file",
                "blob"
              ]
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "condition": "[and(not(empty(parameters('vnetId'))), equals(parameters('environmentName'), 'prod'))]",
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "[variables('privateDnsZoneName')]",
      "location": "global"
    },
    {
      "condition": "[and(not(empty(parameters('vnetId'))), equals(parameters('environmentName'), 'prod'))]",
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', variables('privateDnsZoneName'), format('{0}-vnet-link', variables('storageAccountName')))]",
      "location": "global",
      "properties": {
        "virtualNetwork": {
          "id": "[parameters('vnetId')]"
        },
        "registrationEnabled": false
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/privateDnsZones', variables('privateDnsZoneName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2021-03-01",
      "name": "[format('{0}-plan-{1}', parameters('appName'), parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "tags": "[union(variables('baseTags'), createObject('autoShutdown', if(not(equals(parameters('environmentName'), 'prod')), 'enabled', 'disabled'), 'environmentType', if(equals(parameters('environmentName'), 'prod'), 'production', 'non-production')))]",
      "kind": "linux",
      "sku": {
        "name": "[variables('environmentConfig').sku]",
        "tier": "[variables('environmentConfig').tier]",
        "capacity": "[if(equals(parameters('environmentName'), 'prod'), 2, 1)]"
      },
      "properties": {
        "reserved": true,
        "targetWorkerCount": "[if(equals(parameters('environmentName'), 'prod'), 3, 1)]",
        "perSiteScaling": "[not(equals(parameters('environmentName'), 'prod'))]",
        "maximumElasticWorkerCount": "[if(equals(parameters('environmentName'), 'prod'), 5, 1)]"
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2021-03-01",
      "name": "[format('{0}-api-{1}', parameters('appName'), parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('baseTags')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan-{1}', parameters('appName'), parameters('environmentName')))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "Node|18",
          "appSettings": [
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', variables('storageAccountName'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2021-08-01').keys[0].value)]"
            },
            {
              "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix={1};AccountKey={2}', variables('storageAccountName'), environment().suffixes.storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2021-08-01').keys[0].value)]"
            },
            {
              "name": "WEBSITE_CONTENTSHARE",
              "value": "[toLower(replace(format('{0}-api-{1}', parameters('appName'), parameters('environmentName')), '.', '-'))]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "node"
            },
            {
              "name": "WEBSITE_NODE_DEFAULT_VERSION",
              "value": "~18"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "WEBSITE_LOAD_USER_PROFILE",
              "value": "1"
            },
            {
              "name": "JWT_SECRET",
              "value": "[format('temp-jwt-secret-{0}', uniqueString(resourceGroup().id))]"
            },
            {
              "name": "JWT_REFRESH_SECRET",
              "value": "[format('temp-refresh-secret-{0}', uniqueString(resourceGroup().id))]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan-{1}', parameters('appName'), parameters('environmentName')))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageAccountName'))]",
      "name": "[guid(resourceId('Microsoft.Web/sites', format('{0}-api-{1}', parameters('appName'), parameters('environmentName'))), 'storage-file-role')]",
      "properties": {
        "roleDefinitionId": "/providers/Microsoft.Authorization/roleDefinitions/0c867c2a-37d8-4caa-945d-cc999969dde3",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', format('{0}-api-{1}', parameters('appName'), parameters('environmentName'))), '2021-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', format('{0}-api-{1}', parameters('appName'), parameters('environmentName')))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageAccountName'))]",
      "name": "[guid(resourceId('Microsoft.Web/sites', format('{0}-api-{1}', parameters('appName'), parameters('environmentName'))), 'storage-blob-role')]",
      "properties": {
        "roleDefinitionId": "/providers/Microsoft.Authorization/roleDefinitions/ba92f5b4-2d11-453d-a403-e96b0029c9fe",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', format('{0}-api-{1}', parameters('appName'), parameters('environmentName'))), '2021-03-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', format('{0}-api-{1}', parameters('appName'), parameters('environmentName')))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2021-03-01",
      "name": "[format('{0}-web-{1}', parameters('appName'), parameters('environmentName'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('baseTags')]",
      "sku": {
        "name": "Standard",
        "tier": "Standard"
      },
      "properties": {
        "provider": "GitHub",
        "stagingEnvironmentPolicy": "Enabled",
        "allowConfigFileUpdates": true
      }
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2021-03-01",
      "name": "[format('{0}/{1}', format('{0}-api-{1}', parameters('appName'), parameters('environmentName')), 'web')]",
      "properties": {
        "cors": {
          "allowedOrigins": [
            "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', format('{0}-web-{1}', parameters('appName'), parameters('environmentName'))), '2021-03-01').defaultHostname)]",
            "http://localhost:3000"
          ],
          "supportCredentials": true
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', format('{0}-api-{1}', parameters('appName'), parameters('environmentName')))]",
        "[resourceId('Microsoft.Web/staticSites', format('{0}-web-{1}', parameters('appName'), parameters('environmentName')))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[format('{0}-api-{1}', parameters('appName'), parameters('environmentName'))]"
    },
    "functionAppEndpoint": {
      "type": "string",
      "value": "[format('https://{0}/api', reference(resourceId('Microsoft.Web/sites', format('{0}-api-{1}', parameters('appName'), parameters('environmentName'))), '2021-03-01').defaultHostName)]"
    },
    "staticWebAppName": {
      "type": "string",
      "value": "[format('{0}-web-{1}', parameters('appName'), parameters('environmentName'))]"
    },
    "staticWebAppEndpoint": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/staticSites', format('{0}-web-{1}', parameters('appName'), parameters('environmentName'))), '2021-03-01').defaultHostname)]"
    }
  }
}