{
  "name": "@vcarpool/shared",
  "version": "1.0.0",
  "description": "Shared types and utilities for vcarpool application",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "rimraf dist && mkdir -p dist",
    "build": "tsc --build",
    "build:watch": "tsc --build --watch --preserveWatchOutput",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "type-check:watch": "npm run type-check -- --watch",
    "test": "echo 'Shared package: Running type checks...' && npm run type-check",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "devDependencies": {
    "typescript": "^5.3.3",
    "rimraf": "^5.0.5"
  },
  "dependencies": {
    "zod": "^3.22.4"
  }
}
